  {
    "id": 4,
    "offset": 273586,
    "slot_size": 228,
    "data_size": 224,
    "nom_orig": "Eikichi",
    "texte_orig": "That[SP]guy[SP]ran[SP]off[SP]the[SP]second[SP]he[SP]saw[SP]our[SP]faces!\nHe's[SP]suspicious,[SP]all[SP]right.[SP]Let's[SP]chase[SP]him\ndown,[SP][U+1113]!",
