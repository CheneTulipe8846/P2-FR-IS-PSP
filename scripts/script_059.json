  {
    "id": 6,
    "offset": 274086,
    "slot_size": 178,
    "data_size": 174,
    "nom_orig": "Maya",
    "texte_orig": "That[SP]guy...[1205][001E][SP]I[SP]feel[SP]like[SP]I've[SP]seen[SP]him\nsomewhere.[SP]Well,[SP]after[SP]him,[SP]I[SP]guess!",
